# Circle Environment Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# Required: JWT signing secret
# Generate with: openssl rand -base64 64
CIRCLE_JWT_SECRET=change-me-to-a-random-secret-min-32-chars-long

# Required: Allowed CORS origin (your frontend URL)
# Examples:
#   Local dev:      http://localhost:8080
#   Tailscale:      https://your-host.tailnet-name.ts.net
#   Local network:  http://192.168.1.100:8080
CIRCLE_ALLOWED_ORIGIN=http://localhost:8080

# Optional: Server port (default: 8080)
# CIRCLE_PORT=8080

# Optional: Data directory path (default: ./data)
# CIRCLE_DATA_DIR=/data

# Optional: Maximum upload size in bytes (default: 52428800 = 50MB)
# CIRCLE_MAX_MEDIA_SIZE=52428800

# Optional: Rate limit per minute per IP (default: 100)
# CIRCLE_RATE_LIMIT=100

# Optional: bcrypt password cost (default: 12, range: 4-31)
# CIRCLE_PASSWORD_COST=12

# Optional: Trust the reverse proxy's X-Real-Ip header for the real client IP.
# The docker-compose deployment runs behind nginx and defaults this to true.
# REQUIRED when behind a proxy, otherwise every client shares one rate-limit
# bucket and per-IP login brute-force protection is defeated.
# CIRCLE_TRUST_PROXY=true

# Optional: Mark the session cookie Secure (HTTPS-only). Set to true when the
# proxy terminates HTTPS (e.g. Tailscale, a TLS-terminating reverse proxy).
# Leave false for plain-HTTP local-network deployments. (default: false)
# CIRCLE_COOKIE_SECURE=false
